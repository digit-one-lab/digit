---
import BaseLayout from './BaseLayout.astro';
import { formatDate, readingTime, getPosts, relatedPosts } from '../lib/content';
import PostCard from '../components/PostCard.astro';
const { post } = Astro.props;
const posts = await getPosts();
const related = relatedPosts(post, posts);
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="shell prose article-hero">
    <div class="meta"><span>{post.data.category}</span><span>·</span><span>{formatDate(post.data.date)}</span><span>·</span><span>{readingTime(post.body)} min read</span></div>
    <h1>{post.data.title}</h1>
    <p class="lead">{post.data.description}</p>
    <div class="article-cover"></div>
    <slot />
    <div class="meta" style="margin-top:40px">{post.data.tags.map((tag) => <a class="tag" href={`${import.meta.env.BASE_URL}tags/${tag.toLowerCase().replaceAll(' ', '-')}/`}>{tag}</a>)}</div>
  </article>
  {related.length > 0 && <section class="shell section"><div class="section-head"><h2>Related reading</h2></div><div class="grid posts">{related.map((entry) => <PostCard post={entry} />)}</div></section>}
</BaseLayout>
