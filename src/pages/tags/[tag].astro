---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts, allTags } from '../../lib/content';
function slugify(value: string) { return value.toLowerCase().replaceAll(' ', '-'); }
export async function getStaticPaths() {
  const posts = await getPosts();
  return allTags(posts).map((tag) => ({ params: { tag: slugify(tag) }, props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) } }));
}
const { tag, posts } = Astro.props;
---
<BaseLayout title={`Tag: ${tag}`} description={`Articles tagged ${tag}.`}>
  <section class="shell section">
    <div class="section-head"><h2>{tag}</h2><p>{posts.length} posts</p></div>
    <div class="grid posts">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
