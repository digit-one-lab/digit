---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, allTags } from '../../lib/content';
const tags = allTags(await getPosts());
---
<BaseLayout title="Tags" description="Browse all article tags.">
  <section class="shell section">
    <div class="section-head"><h2>Tags</h2><p>{tags.length} tags</p></div>
    <div class="meta">{tags.map((tag) => <a class="tag" href={`${import.meta.env.BASE_URL}tags/${tag.toLowerCase().replaceAll(' ', '-')}/`}>{tag}</a>)}</div>
  </section>
</BaseLayout>
