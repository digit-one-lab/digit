---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, entrySlug } from '../../lib/content';
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: entrySlug(project) }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="shell prose article-hero">
    <div class="meta"><span>{project.data.status}</span><span>·</span><span>{formatDate(project.data.date)}</span></div>
    <h1>{project.data.title}</h1>
    <p class="lead">{project.data.description}</p>
    <div class="article-cover"></div>
    <Content />
    {project.data.links.length > 0 && <p>{project.data.links.map((link) => <a class="tag" href={link.href}>{link.label}</a>)}</p>}
  </article>
</BaseLayout>
