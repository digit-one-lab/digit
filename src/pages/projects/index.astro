---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects, formatDate, entrySlug } from '../../lib/content';
const projects = await getProjects();
---
<BaseLayout title="Projects" description="Projects, experiments, and systems.">
  <section class="shell section">
    <div class="section-head"><h2>Projects</h2><p>{projects.length} projects</p></div>
    <div class="grid posts">{projects.map((project) => <a class="card" href={`${import.meta.env.BASE_URL}projects/${entrySlug(project)}/`}><div class="cover"></div><div class="meta"><span>{project.data.status}</span><span>·</span><span>{formatDate(project.data.date)}</span></div><h3>{project.data.title}</h3><p>{project.data.description}</p></a>)}</div>
  </section>
</BaseLayout>
