---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, allCategories } from '../../lib/content';
const categories = allCategories(await getPosts());
---
<BaseLayout title="Categories" description="Browse article categories.">
  <section class="shell section">
    <div class="section-head"><h2>Categories</h2><p>{categories.length} categories</p></div>
    <div class="grid posts">{categories.map((category) => <a class="card" href={`${import.meta.env.BASE_URL}categories/${category.toLowerCase().replaceAll(' ', '-')}/`}><h3>{category}</h3><p>Browse all posts in this category.</p></a>)}</div>
  </section>
</BaseLayout>
