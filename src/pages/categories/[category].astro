---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts, allCategories } from '../../lib/content';
function slugify(value: string) { return value.toLowerCase().replaceAll(' ', '-'); }
export async function getStaticPaths() {
  const posts = await getPosts();
  return allCategories(posts).map((category) => ({ params: { category: slugify(category) }, props: { category, posts: posts.filter((post) => post.data.category === category) } }));
}
const { category, posts } = Astro.props;
---
<BaseLayout title={`Category: ${category}`} description={`Articles in ${category}.`}>
  <section class="shell section">
    <div class="section-head"><h2>{category}</h2><p>{posts.length} posts</p></div>
    <div class="grid posts">{posts.map((post) => <PostCard post={post} />)}</div>
  </section>
</BaseLayout>
