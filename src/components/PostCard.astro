---
import { formatDate, readingTime, entrySlug } from '../lib/content';
const { post } = Astro.props;
---
<a class="card" href={`${import.meta.env.BASE_URL}articles/${entrySlug(post)}/`}>
  <div class="cover"></div>
  <div class="meta"><span>{formatDate(post.data.date)}</span><span>·</span><span>{readingTime(post.body)} min read</span></div>
  <h3>{post.data.title}</h3>
  <p>{post.data.description}</p>
  <div class="meta">{post.data.tags.slice(0, 3).map((tag: string) => <span class="tag">{tag}</span>)}</div>
</a>
